# ── Python ───────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── Environnements virtuels ──────────────────────────
venv/
env/
.venv/
.env/

# ── Jupyter ──────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Données sensibles / volumineuses ─────────────────
